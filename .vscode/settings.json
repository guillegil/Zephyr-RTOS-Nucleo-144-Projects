{
  "C_Cpp.intelliSenseEngine": "disabled",
  "C_Cpp.autoAddFileAssociations": false,
  "clangd.arguments": [
    "--background-index",
    "--clang-tidy=false",
    "--completion-style=detailed",
    "--header-insertion=never",
    "--pch-storage=memory",
    "-j=8"
  ],
  "files.watcherExclude": {
    "**/build/**": true,
    "**/.cache/**": true
  },
  "search.exclude": {
    "**/build/**": true,
    "**/.cache/**": true
  }
}